<Window x:Class="VComTunnel.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="VComTunnel" Height="760" Width="1180" MinHeight="620" MinWidth="980"
        Icon="Assets/app.ico">
    <Window.Resources>
        <Style x:Key="ToolBarIconButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="1,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EAEEF2"/>
                    <Setter Property="BorderBrush" Value="#C9D1D9"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#D8DEE4"/>
                    <Setter Property="BorderBrush" Value="#8C959F"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.38"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ToolBarSeparatorStyle" TargetType="{x:Type Border}">
            <Setter Property="Width" Value="1"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Margin" Value="7,4"/>
            <Setter Property="Background" Value="#D0D7DE"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Menu x:Name="MainMenu"
              DockPanel.Dock="Top"
              Background="#F6F8FA"
              BorderBrush="#D0D7DE"
              BorderThickness="0,0,0,1">
            <MenuItem x:Name="MappingsMenuItem" Header="Mappings">
                <MenuItem x:Name="AddMenuItem" Header="Add" Click="Add_Click"/>
                <MenuItem x:Name="SaveMenuItem" Header="Save" Click="Save_Click"/>
                <MenuItem x:Name="DeleteMappingMenuItem" Header="Delete mapping" Click="DeleteMapping_Click"/>
                <Separator/>
                <MenuItem x:Name="StartMappingCommandMenuItem" Header="Start" Click="StartSelectedMapping_Click"/>
                <MenuItem x:Name="StopMappingCommandMenuItem" Header="Stop" Click="StopSelectedMapping_Click"/>
            </MenuItem>
            <MenuItem x:Name="ComPairsMenuItem" Header="COM pairs">
                <MenuItem x:Name="PortsMenuItem" Header="Ports" Click="Ports_Click"/>
                <MenuItem x:Name="CreatePairMenuItem" Header="Create pair" Click="CreatePair_Click"/>
                <MenuItem x:Name="DeletePairMenuItem" Header="Delete pair" Click="DeletePair_Click"/>
                <Separator/>
                <MenuItem x:Name="UpdateKmdfDriverMenuItem" Header="Update KMDF driver" Click="UpdateKmdfDriver_Click"/>
            </MenuItem>
            <MenuItem x:Name="ToolsMenuItem" Header="Tools">
                <MenuItem x:Name="SetupDepsMenuItem" Header="Setup deps" Click="SetupDeps_Click"/>
                <MenuItem x:Name="ClearLogsMenuItem" Header="Clear logs" Click="ClearLogs_Click"/>
            </MenuItem>
            <MenuItem x:Name="LanguageMenuItem" Header="Language">
                <MenuItem x:Name="EnglishLanguageMenuItem"
                          Header="English"
                          IsCheckable="True"
                          Click="EnglishLanguageMenuItem_Click"/>
                <MenuItem x:Name="ChineseLanguageMenuItem"
                          Header="中文"
                          IsCheckable="True"
                          Click="ChineseLanguageMenuItem_Click"/>
            </MenuItem>
            <MenuItem x:Name="ServiceMenuItem" Header="Service">
                <MenuItem x:Name="RefreshMenuItem" Header="Refresh" Click="Refresh_Click"/>
                <MenuItem x:Name="InstallServiceMenuItem" Header="Install background service" Click="InstallService_Click"/>
                <MenuItem x:Name="UninstallServiceMenuItem" Header="Uninstall background service" Click="UninstallService_Click"/>
                <Separator/>
                <MenuItem x:Name="StartServiceMenuItem" Header="Start service" Click="StartService_Click"/>
                <MenuItem x:Name="StopServiceMenuItem" Header="Stop service" Click="StopService_Click"/>
                <MenuItem x:Name="RestartServiceMenuItem" Header="Restart service" Click="RestartService_Click"/>
            </MenuItem>
        </Menu>

        <Border x:Name="IconToolBar"
                DockPanel.Dock="Top"
                Background="#F6F8FA"
                BorderBrush="#D0D7DE"
                BorderThickness="0,0,0,1"
                Padding="4,3">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="RefreshButton"
                        Style="{StaticResource ToolBarIconButtonStyle}"
                        Click="Refresh_Click"/>
                <Border Style="{StaticResource ToolBarSeparatorStyle}"/>
                <Button x:Name="AddButton"
                        Style="{StaticResource ToolBarIconButtonStyle}"
                        Click="Add_Click"/>
                <Button x:Name="SaveButton"
                        Style="{StaticResource ToolBarIconButtonStyle}"
                        Click="Save_Click"/>
                <Button x:Name="DeleteMappingButton"
                        Style="{StaticResource ToolBarIconButtonStyle}"
                        Click="DeleteMapping_Click"/>
                <Border Style="{StaticResource ToolBarSeparatorStyle}"/>
                <Button x:Name="StartButton"
                        Style="{StaticResource ToolBarIconButtonStyle}"
                        Click="StartSelectedMapping_Click"/>
                <Button x:Name="StopButton"
                        Style="{StaticResource ToolBarIconButtonStyle}"
                        Click="StopSelectedMapping_Click"/>
                <Border Style="{StaticResource ToolBarSeparatorStyle}"/>
                <Button x:Name="SetupDepsButton"
                        Style="{StaticResource ToolBarIconButtonStyle}"
                        Click="SetupDeps_Click"/>
                <Button x:Name="ClearLogsButton"
                        Style="{StaticResource ToolBarIconButtonStyle}"
                        Click="ClearLogs_Click"/>
                <Border Style="{StaticResource ToolBarSeparatorStyle}"/>
                <Button x:Name="RestartServiceButton"
                        Style="{StaticResource ToolBarIconButtonStyle}"
                        Click="RestartService_Click"/>
            </StackPanel>
        </Border>

        <StatusBar DockPanel.Dock="Bottom"
                   Background="#F6F8FA"
                   BorderBrush="#D0D7DE"
                   BorderThickness="0,1,0,0">
            <StatusBarItem>
                <TextBlock x:Name="StatusLabel" Text="Status" FontWeight="SemiBold" Foreground="#586069"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem HorizontalContentAlignment="Stretch">
                <TextBlock x:Name="ServiceStateText" TextWrapping="NoWrap"/>
            </StatusBarItem>
        </StatusBar>

        <Grid Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*" MinWidth="560"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="1*" MinWidth="300"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="260"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="210" MinHeight="160"/>
            </Grid.RowDefinitions>

            <GroupBox x:Name="TunnelMappingsGroupBox" Header="Tunnel mappings" Grid.Column="0" Grid.Row="0">
                <DataGrid x:Name="MappingsGrid"
                          Margin="6"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="False"
                          SelectionMode="Single"
                          ColumnWidth="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          ScrollViewer.CanContentScroll="True"
                          EnableColumnVirtualization="True"
                          CellEditEnding="MappingsGrid_CellEditEnding"
                          SelectionChanged="MappingsGrid_SelectionChanged"
                          PreviewKeyDown="MappingsGrid_PreviewKeyDown"
                          ContextMenuOpening="MappingsGrid_ContextMenuOpening"
                          PreviewMouseRightButtonDown="MappingsGrid_PreviewMouseRightButtonDown">
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem x:Name="StartMappingMenuItem"
                                      Header="Start"
                                      Click="StartSelectedMapping_Click"/>
                            <MenuItem x:Name="StopMappingMenuItem"
                                      Header="Stop"
                                      Click="StopSelectedMapping_Click"/>
                            <Separator/>
                            <MenuItem x:Name="SaveSelectedMappingMenuItem"
                                      Header="Save"
                                      Click="Save_Click"/>
                            <MenuItem x:Name="DeleteSelectedMappingMenuItem"
                                      Header="Delete mapping"
                                      Click="DeleteMapping_Click"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTextColumn x:Name="MappingStateColumn" Header="State" Binding="{Binding StateLabel}" Width="Auto" MinWidth="90" IsReadOnly="True"/>
                        <DataGridTextColumn x:Name="NameColumn" Header="Name" Binding="{Binding Name}" Width="Auto" MinWidth="120"/>
                        <DataGridComboBoxColumn x:Name="BackendColumn" Header="Backend" SelectedItemBinding="{Binding Backend, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="Auto" MinWidth="150">
                            <DataGridComboBoxColumn.ItemsSource>
                                <x:Array Type="{x:Type sys:String}">
                                    <sys:String>com0comHub4com</sys:String>
                                    <sys:String>com0comService</sys:String>
                                    <sys:String>kmdf</sys:String>
                                </x:Array>
                            </DataGridComboBoxColumn.ItemsSource>
                        </DataGridComboBoxColumn>
                        <DataGridTextColumn x:Name="VisibleComColumn" Header="Visible COM" Binding="{Binding VisiblePort}" Width="Auto" MinWidth="110"/>
                        <DataGridTextColumn x:Name="BackingColumn" Header="Backing" Binding="{Binding BackingPort}" Width="Auto" MinWidth="110"/>
                        <DataGridTextColumn x:Name="HostColumn" Header="Host" Binding="{Binding Host}" Width="Auto" MinWidth="150"/>
                        <DataGridTextColumn x:Name="PortColumn" Header="Port" Binding="{Binding Port}" Width="Auto" MinWidth="72"/>
                        <DataGridCheckBoxColumn x:Name="Hub4comControlsColumn" Header="Controls" Binding="{Binding Hub4comForwardControlLines, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="SizeToHeader" MinWidth="78"/>
                        <DataGridCheckBoxColumn x:Name="AutoColumn" Header="Auto" Binding="{Binding AutoStart, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="SizeToHeader" MinWidth="64"/>
                        <DataGridCheckBoxColumn x:Name="RestartColumn" Header="Restart" Binding="{Binding RestartOnFailure}" Width="SizeToHeader" MinWidth="72"/>
                        <DataGridTextColumn x:Name="ServiceColumn" Header="Service" Binding="{Binding ServiceLabel}" Width="Auto" MinWidth="180" IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <GridSplitter Grid.Column="1"
                          Grid.Row="0"
                          Width="8"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="Transparent"/>

            <GroupBox x:Name="DependenciesGroupBox" Header="Dependencies / COM pairs" Grid.Column="2" Grid.Row="0">
                <Grid Margin="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="170" MinHeight="120"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="*" MinHeight="100"/>
                    </Grid.RowDefinitions>

                    <StackPanel x:Name="DependencyProgressPanel"
                                Grid.Row="0"
                                Visibility="Collapsed"
                                Margin="0,0,0,2">
                        <TextBlock x:Name="DependencyProgressText"
                                   Text="Preparing dependencies..."
                                   Foreground="#586069"
                                   FontSize="12"
                                   Margin="0,0,0,4"/>
                        <ProgressBar x:Name="DependencyProgressBar"
                                     Height="6"
                                     IsIndeterminate="True"/>
                    </StackPanel>

                    <ListView x:Name="ComPairsList"
                              Grid.Row="2"
                              SelectionMode="Single"
                              SelectionChanged="ComPairsList_SelectionChanged"
                              PreviewMouseRightButtonDown="ComPairsList_PreviewMouseRightButtonDown">
                        <ListView.ContextMenu>
                            <ContextMenu>
                                <MenuItem x:Name="DeleteSelectedComPairMenuItem"
                                          Header="Delete pair"
                                          Click="DeleteSelectedComPair_Click"/>
                            </ContextMenu>
                        </ListView.ContextMenu>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn x:Name="PairNumberColumn" Header="Type" DisplayMemberBinding="{Binding Kind}" Width="72"/>
                                <GridViewColumn x:Name="PairPortAColumn" Header="Port" DisplayMemberBinding="{Binding Port}" Width="86"/>
                                <GridViewColumn x:Name="PairPortBColumn" Header="Details" DisplayMemberBinding="{Binding Details}" Width="160"/>
                                <GridViewColumn x:Name="PairStateColumn" Header="State" DisplayMemberBinding="{Binding State}" Width="72"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <GridSplitter Grid.Row="3"
                                  Height="6"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  ResizeDirection="Rows"
                                  Background="Transparent"/>

                    <TextBox x:Name="DependenciesText"
                             Grid.Row="4"
                             IsReadOnly="True"
                             TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas"/>
                </Grid>
            </GroupBox>

            <GridSplitter Grid.ColumnSpan="3"
                          Grid.Row="1"
                          Height="8"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          ResizeDirection="Rows"
                          Background="Transparent"/>

            <GroupBox x:Name="LogsGroupBox" Header="Logs" Grid.ColumnSpan="3" Grid.Row="2">
                <TextBox x:Name="LogsText"
                         Margin="6"
                         IsReadOnly="True"
                         TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         FontSize="12"/>
            </GroupBox>
        </Grid>
    </DockPanel>
</Window>

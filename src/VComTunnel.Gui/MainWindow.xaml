<Window x:Class="VComTunnel.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="VComTunnel" Height="720" Width="1120" MinHeight="560" MinWidth="920">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="VComTunnel" FontSize="24" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,18,0"/>
            <Button Content="Refresh" Width="88" Margin="0,0,8,0" Click="Refresh_Click"/>
            <Button Content="Setup deps" Width="104" Margin="0,0,8,0" Click="SetupDeps_Click"/>
            <Button Content="Add" Width="72" Margin="0,0,8,0" Click="Add_Click"/>
            <Button Content="Save" Width="72" Margin="0,0,8,0" Click="Save_Click"/>
            <Button Content="Start" Width="72" Margin="0,0,8,0" Click="Start_Click"/>
            <Button Content="Stop" Width="72" Margin="0,0,8,0" Click="Stop_Click"/>
            <Button Content="Ports" Width="72" Margin="0,0,8,0" Click="Ports_Click"/>
            <Button Content="Create pair" Width="96" Margin="0,0,8,0" Click="CreatePair_Click"/>
            <Button Content="Delete pair" Width="96" Margin="0,0,8,0" Click="DeletePair_Click"/>
            <Button Content="Clear logs" Width="88" Margin="0,0,8,0" Click="ClearLogs_Click"/>
            <TextBlock x:Name="ServiceStateText" VerticalAlignment="Center" Margin="18,0,0,0"/>
        </StackPanel>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>

            <DataGrid x:Name="MappingsGrid"
                      Grid.Column="0"
                      Grid.Row="0"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="False"
                      SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="1.2*"/>
                    <DataGridComboBoxColumn Header="Backend" SelectedItemBinding="{Binding Backend}" Width="150">
                        <DataGridComboBoxColumn.ItemsSource>
                            <x:Array Type="{x:Type sys:String}">
                                <sys:String>com0comHub4com</sys:String>
                                <sys:String>kmdf</sys:String>
                            </x:Array>
                        </DataGridComboBoxColumn.ItemsSource>
                    </DataGridComboBoxColumn>
                    <DataGridTextColumn Header="Visible COM" Binding="{Binding VisiblePort}" Width="110"/>
                    <DataGridTextColumn Header="Backing" Binding="{Binding BackingPort}" Width="110"/>
                    <DataGridTextColumn Header="Host" Binding="{Binding Host}" Width="1.3*"/>
                    <DataGridTextColumn Header="Port" Binding="{Binding Port}" Width="80"/>
                    <DataGridCheckBoxColumn Header="Auto" Binding="{Binding AutoStart}" Width="70"/>
                    <DataGridCheckBoxColumn Header="Restart" Binding="{Binding RestartOnFailure}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>

            <GroupBox Header="Dependencies" Grid.Column="2" Grid.Row="0">
                <TextBox x:Name="DependenciesText" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
            </GroupBox>

            <GroupBox Header="Logs" Grid.ColumnSpan="3" Grid.Row="2">
                <TextBox x:Name="LogsText" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontFamily="Consolas"/>
            </GroupBox>
        </Grid>
    </DockPanel>
</Window>
